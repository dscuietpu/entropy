# Copy to .env and fill values. Required keys are validated at startup (see src/config/env.ts).

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Required ---
MONGO_URI=
JWT_SECRET=

# --- Cloudinary (file uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Hugging Face (semantic search embeddings; optional for CRUD) ---
HF_API_KEY=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- OpenRouter (AI routes under /api/ai; optional) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-lite
